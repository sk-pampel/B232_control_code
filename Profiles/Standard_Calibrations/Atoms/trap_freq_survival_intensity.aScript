var loadingdepth 14 %12 %15.25
var imagingDepth 10 %14 %18.5
var intrappgcDepth 19.5
var modulationdepth 16 %17.8
var dropDepth 16

hold loadingDepth 1 oncewaittrig #  
ramp lin loadingDepth imagingdepth 1 oncewaittrig #
ramp lin imagingdepth intrappgcDepth 1 oncewaittrig #
ramp lin intrappgcDepth modulationdepth 1 oncewaittrig #
ramp lin modulationdepth dropDepth 1 oncewaittrig #
ramp lin dropDepth imagingdepth 1 oncewaittrig #
ramp lin imagingdepth loadingDepth 1 once #  
